# ===========================
# ShopVN - Environment Config
# ===========================
# Copy file này thành .env và điền giá trị thật trước khi chạy

# --- Backend ---

# MongoDB URI — để trống hoặc 'local' để dùng in-memory (dev)
MONGODB_URI=

# JWT Secret — thay bằng chuỗi ngẫu nhiên dài trước khi deploy
JWT_SECRET=your-strong-jwt-secret-here

# App Secret — dùng để xác thực request nội bộ (FE ↔ BE)
# Phải giống nhau ở cả backend và frontend
APP_SECRET=your-strong-app-secret-here

# Stripe Secret Key — lấy tại https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE

# Port backend (mặc định: 3001)
PORT=3001

# --- Frontend (Vite) ---

# Phải có prefix VITE_ để Vite expose ra client
VITE_APP_SECRET=your-strong-app-secret-here

# --- Automation Tests ---

# NODE_ENV=test để bypass rate limiting khi chạy tests
NODE_ENV=test
