# ===========================
# ShopVN - Environment Config
# ===========================
# Copy file này thành .env và điền giá trị thật trước khi chạy

# --- Backend ---

# MongoDB URI — để trống hoặc 'local' để dùng in-memory (dev)
MONGODB_URI=

# JWT Secret — thay bằng chuỗi ngẫu nhiên dài trước khi deploy lên production
JWT_SECRET=shopvn-dev-jwt-secret

# App Secret — dùng để xác thực request nội bộ (FE ↔ BE)
# APP_SECRET và VITE_APP_SECRET phải có cùng giá trị
# Thay bằng chuỗi ngẫu nhiên trước khi deploy lên production
APP_SECRET=shopvn-dev-app-secret

# Stripe Secret Key — lấy tại https://dashboard.stripe.com/test/apikeys
# Để giá trị mặc định nếu không có Stripe key (mock mode)
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE

# Port backend (mặc định: 3001)
PORT=3001

# --- Frontend (Vite) ---

# Phải có prefix VITE_ để Vite expose ra client — phải khớp với APP_SECRET bên trên
VITE_APP_SECRET=shopvn-dev-app-secret

# --- Automation Tests ---

# NODE_ENV=test để bypass rate limiting khi chạy tests
NODE_ENV=test
